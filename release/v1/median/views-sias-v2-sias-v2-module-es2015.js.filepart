nline: 150px;\">\r\n          <mat-label>FCY Exchange Rate Variance percentage</mat-label>\r\n          <input matInput type=\"text\" [(ngModel)]=\"createExtSys1.fCYPercentage\" name=\"fCYPercentage\"\r\n            [disabled]=\"!is_edit1\" required>\r\n        </mat-form-field>\r\n  \r\n      </div>\r\n  \r\n    </div>\r\n    <div fxLayout=\"row wrap\" fxLayoutGap=\"10\">\r\n    \r\n      <div fxFlex=\"25\">\r\n    \r\n        <mat-checkbox (change)=getValue2($event)> Cross Financial Transaction.</mat-checkbox>\r\n      </div>\r\n  \r\n      <div fxFlex=\"25\">\r\n  \r\n        <mat-checkbox (change)=getValueSftp($event)>SFTP Required</mat-checkbox>\r\n      </div>\r\n      <div fxFlex=\"25\">\r\n  \r\n        <mat-checkbox (change)=getValueMfI($event)>Mandatory Field Impose</mat-checkbox>\r\n      </div>\r\n  \r\n    </div>\r\n  \r\n    <div fxLayout=\"row\" fxLayoutAlign=\"center center\" fxLayoutGap=\"10px\">\r\n        <button #saveBtn type=\"submit\" mat-raised-button color=\"primary\" (click)=\"save(extSysCode.value)\"\r\n          [disabled]=\"!fn.form.valid\" *ngIf=\"!savebutton||!is_sftp\">Save</button>\r\n        <button mat-raised-button color=\"warn\" [routerLink]=\"'/sias-v2/ExtSysList'\">Exit</button>\r\n      </div>\r\n      <div fxLayout=\"column wrap\" fxFlex=\"45\" > \r\n   \r\n          <span>SFTP Details</span>\r\n          <mat-form-field class=\"full-width\" appearance=\"outline\">\r\n              <mat-label>UserName</mat-label>\r\n              <input matInput type=\"text\"\r\n              placeholder=\"UserName\"  [(ngModel)]=\"createExtSys1.userName\" name=\"userName\"\r\n                required>\r\n            </mat-form-field>\r\n            <mat-form-field class=\"full-width\" appearance=\"outline\">\r\n                <mat-label>Password</mat-label>\r\n                <input matInput type=\"text\" \r\n                placeholder=\"Password\" [(ngModel)]=\"createExtSys1.password\" name=\"password\"\r\n                  required>\r\n  